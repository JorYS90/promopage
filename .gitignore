node_modules/
dist/
.DS_Store
.env
.env.local
.env.*.local
.env.deploy
.vite/

# Claude Code — configs locais do dev (cada um tem o seu)
.claude/settings.local.json

# Docker Compose override local — cada dev resolve seus conflitos de porta
docker-compose.override.yml

# Uploads de usuário (NÃO commitar) — exceto assets do produto (balões, imagens IA dos temas)
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/baloes/
backend/uploads/baloes/*
!backend/uploads/baloes/**/
!backend/uploads/baloes/**/*.png
!backend/uploads/baloes/INDEX.md
!backend/uploads/ai/
!backend/uploads/ai/*.png

# Projetos salvos (dados de usuário)
backend/projetos/*
!backend/projetos/.gitkeep

# Banco SQLite + WAL/SHM (dados sensíveis: usuários, hashes, sessões)
backend/data/saas.db
backend/data/saas.db-shm
backend/data/saas.db-wal
backend/data/saas.db.bak-*
backend/data/saas.db.pre-*
backend/data/saas.db-shm.pre-*
backend/data/saas.db-wal.pre-*
backend/data/backups-imagens/

# Backups locais
backend/backups/

# Backups automáticos criados pelos scripts de deploy/setup
backend/uploads.bak-*/
backend/templates.bak-*/
backend/data/.migration-*

# Cache local de busca de imagens (gerenciado pela app — não versionar)
backend/data/imagens-produtos.json
backend/data/google-cse-quota.json
backend/data/categorias.json.migrated

# Logs
*.log
backend/logs/

# Sistema
Thumbs.db
