# =============================================
# Encarte Builder / PromoPage — Backend env (EXEMPLO)
# =============================================
# Copie esse arquivo pra .env e preencha os valores.
# Em produção, regenere o JWT_SECRET com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

NODE_ENV=production
PORT=4010

# JWT — DEVE ser um string aleatório de 48+ caracteres em produção
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# CORS — em produção, defina o domínio real (sem trailing slash):
#   CORS_ORIGIN=https://promopage.com.br
# Pra liberar múltiplos domínios (ex: subdomínios do PromoVideo), separe por vírgula:
#   CORS_ORIGIN=https://promopage.com.br,https://www.promopage.com.br,https://videos.promopage.com.br
CORS_ORIGIN=https://seu-dominio.com.br

# Rate limit — limites por IP (ajuste conforme tráfego esperado)
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=10

# Cookies — em produção (HTTPS) MANTENHA true (cookies só vão via HTTPS)
SECURE_COOKIES=true

# Cookie domain — pra compartilhar auth entre subdomínios (PromoPage + PromoVideo).
# Em prod: ".promopage.com.br" (com PONTO inicial = vale em TODOS subdomínios).
# Em dev: deixa VAZIO (localhost não tem subdomínios, cada porta é "site" separado).
COOKIE_DOMAIN=

# Banco — caminho do arquivo SQLite (relativo ou absoluto)
# DB_FILE=/var/data/saas.db

# Buscadores de imagem (opcional)
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=
BING_API_KEY=

# Email (Resend) — usado pra reset de senha
# Cria conta em https://resend.com e copia a API key (começa com re_)
# Sem RESEND_API_KEY: backend NÃO envia email (em dev, exibe link no response;
# em prod, o usuário fica órfão — reset desabilitado).
RESEND_API_KEY=
# Remetente. Sem domínio verificado no Resend, use o sandbox abaixo
# (só envia pro email do dono da conta Resend).
# Com domínio verificado: troca pra algo como nao-responder@seudominio.com.br
EMAIL_FROM=onboarding@resend.dev
# URL pública do app — usada pra montar o link de reset enviado por email
# E TAMBÉM nas back_urls/webhook do Mercado Pago. Em PROD aponte pro domínio
# (mesmo host serve front + /api): https://promopage.com.br
# Local (front Vite): http://localhost:5173
APP_BASE_URL=http://localhost:5173

# E-mail do admin que recebe as "Solicitações de tema"
ADMIN_EMAIL=admin@promopage.com.br

# Mercado Pago — Checkout Pro (pagamentos)
# Pegue em https://www.mercadopago.com.br/developers → Suas integrações → Credenciais
#   Teste:    TEST-...      (sandbox, não cobra de verdade)
#   Produção: APP_USR-...   (cobra real)
# Sem token: pagamentos ficam desativados (checkout retorna 503).
MP_ACCESS_TOKEN=
