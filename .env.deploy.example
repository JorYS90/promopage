# =====================================================================
# Configuração de DEPLOY (não-secreta, mas .env.deploy fica no .gitignore)
# =====================================================================
# 1. cp .env.deploy.example .env.deploy
# 2. Edita os valores abaixo com os dados do SEU VPS

# IP ou domínio do VPS
VPS_HOST=123.45.67.89

# Usuário SSH (criado no setup-vps.sh; nunca use root)
VPS_USER=promopage

# Caminho do projeto no VPS
VPS_PATH=/home/promopage/promopage

# URL pra healthcheck (deve responder 200 quando site está OK)
# Local pra teste: http://localhost/api/health
# Produção:       https://seudominio.com.br/api/health
HEALTH_URL=https://seudominio.com.br/api/health
